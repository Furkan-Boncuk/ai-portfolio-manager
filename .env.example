# =============================================================================
# Portfolio AI Signal Agent — Environment Variables
# =============================================================================
# Usage: cp .env.example .env
# .env is gitignored — never commit it
# =============================================================================

# ── PostgreSQL ──────────────────────────────────────────────────────────────
DATABASE_URL=postgres://portfolio:portfolio_pass@postgres:5432/portfolio_agent
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=portfolio_pass
POSTGRES_DB=portfolio_agent
POSTGRES_PORT=5432

# ── API ─────────────────────────────────────────────────────────────────────
API_PORT=3000
LOCAL_AUTH_TOKEN=dev-local-token-change-me
CORS_ORIGIN=http://localhost:5173

# ── Frontend ────────────────────────────────────────────────────────────────
# VITE_ prefixed vars are embedded in the client bundle — never put secrets here
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:3000
VITE_SSE_URL=http://localhost:3000/api/v1/events/stream
VITE_DEFAULT_TOKEN=dev-local-token-change-me

# ── Telegram (optional — leave empty to disable notifications) ──────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Ollama (optional — deterministic flow works without it) ─────────────────
OLLAMA_BASE_URL=http://ollama:11434/api
OLLAMA_CHAT_MODEL=qwen3:8b
OLLAMA_EMBEDDING_MODEL=embeddinggemma
OLLAMA_PORT=11434

# ── Market Data ─────────────────────────────────────────────────────────────
MARKET_DATA_PROVIDER=binance
BINANCE_PUBLIC_BASE_URL=https://api.binance.com

# ── Worker ──────────────────────────────────────────────────────────────────
WORKER_POLL_INTERVAL_MS=30000
MAX_DAILY_SIGNALS=20
SIGNAL_COOLDOWN_MINUTES=30

# ── Redis (optional — activate with profile: redis) ─────────────────────────
REDIS_PORT=6379
